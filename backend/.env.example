# Database
MONGODB_URI=mongodb://localhost:27017/job-pulse

# Server
PORT=3000
NODE_ENV=development

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# APIs
SERPAPI_KEY=your_serpapi_key_here

# Scoring Weights (0-1)
RECENCY_WEIGHT=0.6
RELEVANCE_WEIGHT=0.4

# Refresh intervals (in hours)
FETCH_INTERVAL_HOURS=3

# ========================================
# Job Ingestion API Cost Optimization
# ========================================
# SerpAPI Budget: 240 requests/month (free tier)
# Cost: 1 request = ~10 jobs
# Formula: (MAX_JOBS_PER_COUNTRY ÷ 10) × num_countries = requests_per_run
#
# Examples:
# - 50 jobs × 3 countries = 15 requests/run = 16 runs/month (current default)
# - 20 jobs × 3 countries = 6 requests/run = 40 runs/month
# - 50 jobs × 1 country = 5 requests/run = 48 runs/month
#
# Adjust based on your needs:
# - Want daily runs? Reduce to 20-30 jobs or fewer countries
# - Want more data? Pay for more SerpAPI credits
# - Want India only? Set COUNTRIES_TO_FETCH=India

# Maximum jobs to fetch per country (default: 50)
# Reduces costs if you need less data
# Each 10 jobs = 1 SerpAPI request
# Example: 20 jobs = 2 requests, 50 jobs = 5 requests
MAX_JOBS_PER_COUNTRY=50

# Countries to fetch from (comma-separated, default: India,United States,United Kingdom)
# Options: India, United States, United Kingdom, Canada, Germany, France, Japan, etc.
# To save API budget, use fewer countries:
# - India only: COUNTRIES_TO_FETCH=India (5 requests/run)
# - India + USA: COUNTRIES_TO_FETCH=India,United States (10 requests/run)
COUNTRIES_TO_FETCH=India,United States,United Kingdom

# Include free Remotive API (default: true)
# Remotive has no cost and no request limit
# Set to false to skip Remotive (rare)
INCLUDE_REMOTIVE=true

# Admin API Key (protects /admin/ingest endpoint)
ADMIN_API_KEY=<your_admin_api_key_here>

INCLUDE_GOOGLE_JOBS=true

    
